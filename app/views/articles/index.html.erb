<p style="color: green"><%= notice %></p>

<% content_for :title, "記事一覧" %>

<h1>記事一覧</h1>

<%= turbo_frame_tag "articles" do %>
  <div id="articles">
    <% @articles.each do |article| %>
      <%= render article %>
      <p>
        <%= link_to "詳細", article %>
      </p>
    <% end %>
  </div>
<% end %>

<%= link_to "新規作成", new_article_path %>
