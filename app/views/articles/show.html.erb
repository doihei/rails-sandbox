<p style="color: green"><%= notice %></p>

<%= turbo_frame_tag "articles" do %>
  <%= render @article %>

  <div>
    <% if @article.status != "published" && @article.user == current_user %>
      <%= link_to "公開", publish_article_path(@article),
        method: :patch,
        data: { turbo_confirm: "この記事を公開しますか？" } %> |
    <% end %>
    <%= link_to "編集", edit_article_path(@article) %> |
    <%= link_to "削除", @article, method: :delete %>
    <br>
    <%= link_to "戻る", articles_path %>
  </div>
<% end %>
